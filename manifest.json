{
  "manifest_version": 3,
  "name": "Geared AI 브라우저 자동화 도구",
  "version": "1.0.0",
  "description": "자연어로 작업을 설명하면 DeepSeek 또는 OpenAI가 크롤링 액션 스펙(JSON)을 생성하고, 익스텐션이 실행해 데이터를 추출·다운로드합니다.",
  "permissions": ["scripting", "downloads", "tabs", "activeTab", "storage", "debugger"],
  "host_permissions": ["<all_urls>", "https://api.deepseek.com/*", "https://api.openai.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Geared AI 브라우저 자동화 도구"
  },
  "incognito": "spanning",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
